{
  "name": "solenne",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "bun run --filter '*' build",
    "lint": "bun run --filter '*' lint",
    "prisma:migrate": "bun run --cwd apps/api prisma:migrate",
    "prisma:seed": "bun run --cwd apps/api prisma:seed"
  }
}
